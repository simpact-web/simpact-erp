# =============================================================================
#  MEDIA STACK - Variables d'environnement
#  Copiez ce fichier en .env et adaptez les valeurs à votre serveur
#  cp .env.example .env && nano .env
# =============================================================================

# --- Identité de l'utilisateur système ---
# Obtenir les valeurs avec la commande : id $(whoami)
PUID=1000
PGID=1000

# --- Fuseau horaire ---
# Liste complète : https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Europe/Paris

# --- Adresse IP de votre serveur (locale) ---
# Obtenir avec : hostname -I | awk '{print $1}'
SERVER_IP=192.168.1.100

# --- Répertoires de base (chemin absolu sur le serveur) ---
# Ne pas modifier si vous utilisez le script setup.sh
CONFIG_DIR=/home/user/mediastack/config
DATA_DIR=/home/user/mediastack/data
